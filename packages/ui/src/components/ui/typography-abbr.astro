---
/**
 * Abbr - Abbreviation with tooltip (Astro). Zero client JavaScript.
 * For acronyms or technical terms that need explanation.
 *
 * @cognitive-load 1/10
 */
import type { HTMLAttributes } from 'astro/types';
import classy from '../../primitives/classy';
import { resolveTypography } from './typography.classes';

interface Props extends HTMLAttributes<'abbr'> {
  title: string;
  size?: string;
  weight?: string;
  color?: string;
  line?: string;
  tracking?: string;
  family?: string;
  align?: string;
  transform?: string;
}

const {
  title,
  size,
  weight,
  color,
  line,
  tracking,
  family,
  align,
  transform,
  class: className,
  ...attrs
} = Astro.props;
const classes = classy(
  resolveTypography('abbr', { size, weight, color, line, tracking, family, align, transform }),
  className,
);
---

<abbr class={classes} title={title} {...attrs}><slot /></abbr>
