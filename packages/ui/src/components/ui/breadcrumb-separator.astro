---
import type { HTMLAttributes } from 'astro/types';
import classy from '../../primitives/classy';
import { breadcrumbSeparatorClasses } from './breadcrumb.classes';

interface Props extends HTMLAttributes<'li'> {}

const { class: className, ...attrs } = Astro.props;
const hasCustomSeparator = Astro.slots.has('default');
---

<li role="presentation" aria-hidden="true" class={classy(breadcrumbSeparatorClasses, className)} {...attrs}>
  {hasCustomSeparator ? <slot /> : (
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m9 18 6-6-6-6" />
    </svg>
  )}
</li>
