---
/**
 * Flexible container component for grouping related content (Astro)
 *
 * Zero client JavaScript. Server-rendered markup with Tailwind tokens.
 * Sub-components: card-header.astro, card-title.astro, card-description.astro,
 * card-content.astro, card-footer.astro, card-action.astro
 *
 * @cognitive-load 2/10
 * @accessibility Proper heading structure, landmark roles
 */
import type { HTMLAttributes } from 'astro/types';
import classy from '../../primitives/classy';
import { resolveFillName } from '../../primitives/fill-resolver';
import {
  type CardBackground,
  cardBackgroundClasses,
  cardBaseClasses,
  cardInteractiveClasses,
} from './card.classes';

type CardElement = 'div' | 'article' | 'section' | 'aside';

interface Props extends HTMLAttributes<'div'> {
  as?: CardElement;
  interactive?: boolean;
  size?: 'default' | 'sm';
  /** @deprecated Prefer the `fill` prop. */
  background?: CardBackground;
  /**
   * Fill token name resolved through the fill registry in surface context.
   * Overrides the default `bg-card` surface when set.
   */
  fill?: string;
}

const {
  as: Tag = 'div',
  interactive,
  size = 'default',
  background,
  fill,
  class: className,
  ...attrs
} = Astro.props;

const sizeStyles = size === 'sm' ? 'group/card-sm' : '';
const fillClasses = fill ? resolveFillName(fill, 'surface') : '';
// fill wins over legacy background
const bgStyles = !fill && background ? cardBackgroundClasses[background] : '';
const cls = classy(
  cardBaseClasses,
  sizeStyles,
  interactive ? cardInteractiveClasses : '',
  bgStyles,
  fillClasses,
  className,
);
---

<Tag
  class={cls}
  tabindex={interactive ? 0 : undefined}
  data-fill={fill || undefined}
  {...attrs}
>
  <slot />
</Tag>
